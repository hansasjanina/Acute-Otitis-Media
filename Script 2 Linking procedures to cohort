##            Procedure codes: DCA20 and SPAT1019
## ============================================================================

# --- 5.1 Read and filter AvoHILMO procedure files for DCA20 or SPAT1019 -----

aht1 <- fread("/media/volume/Data_20260319//THL//FD_2698_THL2023_2698_AH_TOIMENPITEET_1.csv")
filtered_1 <- subset(aht1, grepl("DCA20|1019", TOIMENPIDE, ignore.case = TRUE))

aht2 <- fread("/media/volume/Data_20260319//THL//FD_2698_THL2023_2698_AH_TOIMENPITEET_2.csv")
filtered_2 <- subset(aht2, grepl("DCA20|1019", TOIMENPIDE, ignore.case = TRUE))

aht3 <- fread("/media/volume/Data_20260319//THL//FD_2698_THL2023_2698_AH_TOIMENPITEET_3.csv")
filtered_3 <- subset(aht3, grepl("DCA20|1019", TOIMENPIDE, ignore.case = TRUE))

aht4 <- fread("/media/volume/Data_20260319//THL//FD_2698_THL2023_2698_AH_TOIMENPITEET_4.csv")
filtered_4 <- subset(aht4, grepl("DCA20|1019", TOIMENPIDE, ignore.case = TRUE))

# Combine all AvoHILMO procedure records
toimenpiteet <- bind_rows(filtered_1, filtered_2, filtered_3, filtered_4)
toimenpiteet$AVOHILMOID <- as.character(toimenpiteet$AVOHILMOID)

toimenpiteet %>% write_parquet(paste0("/media/volume/JaninaH/", "avohilmo_putkitukset"))
toimenpiteet <- read_parquet(paste0("/media/volume/JaninaH/", "avohilmo_putkitukset"))

# Merge AvoHILMO diagnosis data with procedure data on patient and visit IDs
ahs <- left_join(avot, toimenpiteet,
                 by = c("FID" = "FID", "AVOHILMOID" = "AVOHILMOID"))
table(ahs$TOIMENPIDE)


## ============================================================================
## SECTION 6: Combine HILMO and AvoHILMO Data
## ============================================================================

# Mark data source (AH = AvoHILMO primary care; H = HILMO specialised care)
ahs$PALVELUNTUOTTAJA <- as.character(ahs$PALVELUNTUOTTAJA)
ahs["data"]    <- "AH"
hilmot["data"] <- "H"

ahs %>% write_parquet(paste0("/media/volume/JaninaH/", "avohilmo_myos_tp.parquet"))
ahs <- read_parquet(paste0("/media/volume/JaninaH/", "avohilmo_myos_tp.parquet"))

# Harmonise column names across AvoHILMO and HILMO for combining
colnames(ahs)[3]  <- "PALTU"          # Service provider
colnames(ahs)[4]  <- "PVM"            # Visit date
colnames(ahs)[1]  <- "AVOTAIHILMOID"  # Visit ID (AvoHILMO or HILMO)
colnames(ahs)[12] <- "TOIMP"          # Procedure code
colnames(ahs)[7]  <- "Syntymapaiva"   # Date of birth
colnames(ahs)[9]  <- "kieli"          # Native language
ahs <- subset(ahs, select = -c(11))   # Remove redundant column

colnames(hilmot)[4] <- "PVM"
colnames(hilmot)[3] <- "FID"
colnames(hilmot)[1] <- "AVOTAIHILMOID"
hilmot <- subset(hilmot, select = -c(3, 13, 14, 16))
colnames(hilmot)[9] <- "kieli"

# Restrict AvoHILMO data to study period (2017–2022)
ahs <- ahs %>%
  filter(PVM >= as.Date("2017-01-01") & PVM <= as.Date("2022-12-31"))

# Remove duplicate visits: same date, patient, procedure code, and diagnosis
ahs <- ahs %>%
  distinct(PVM, FID, TOIMP, KOODI, .keep_all = TRUE)

sum(is.na(ahs$KOODI))

# Combine HILMO and AvoHILMO into a single dataset
avoh <- bind_rows(hilmot, ahs)
avoh %>% write_parquet(paste0("/media/volume/JaninaH/", "avojahilmo_tp.parquet"))
cdf1 <- read_parquet(paste0("/media/volume/JaninaH/", "avojahilmo_tp.parquet"))


