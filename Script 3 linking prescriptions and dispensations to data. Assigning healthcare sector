## ============================================================================
## SECTION 7: Antibiotic Prescriptions (Reseptikeskus / Prescription Centre)
## ============================================================================

# --- 7.1 Prepare year-specific patient ID sets for memory-efficient
#         chunked reading of large prescription files -------------------------

df1_filtered17 <- cdf1 %>% filter(format(PVM, "%Y") == "2017")
id17 <- unique(df1_filtered17$FID)

df1_filtered18 <- cdf1 %>% filter(format(PVM, "%Y") == "2018")
id18 <- unique(df1_filtered18$FID)

df1_filtered19 <- cdf1 %>% filter(format(PVM, "%Y") == "2019")
id19 <- unique(df1_filtered19$FID)

df1_filtered20 <- cdf1 %>% filter(format(PVM, "%Y") == "2020")
id20 <- unique(df1_filtered20$FID)

df1_filtered21 <- cdf1 %>% filter(format(PVM, "%Y") == "2021")
id21 <- unique(df1_filtered21$FID)

df1_filtered22 <- cdf1 %>% filter(format(PVM, "%Y") == "2022")
id22 <- unique(df1_filtered22$FID)


# --- 7.2 Read prescription data in 3-million-row chunks, filtering to
#         study patients. Repeat this block for each year (2017–2022),
#         updating csv_name and the id## reference accordingly. ---------------

csv_name <- "/media/volume/Data_20260319//Reseptikeskus//FD_2698_166_522_2023_Laakemaaraykset_2017.csv"

results      <- list()       # Initialise list to collect filtered chunks
chunk_size   <- 3000000      # Process 3,000,000 rows per chunk

chunk_handler <- function(df, pos) {
  # Retain only prescriptions belonging to study patients (year-specific IDs)
  df_filtered <- df %>% filter(FID %in% id17)  # Update year for each iteration
  results <<- append(results, list(df_filtered))
}

read_delim_chunked(
  file     = csv_name,
  callback = DataFrameCallback$new(chunk_handler),
  delim    = ";",
  locale   = locale(encoding = "UTF-8"),
  chunk_size = chunk_size,
  col_types = cols(
    FID                        = col_character(),
    SECTOR                     = col_character(),   # Public (1) or private (2) sector
    DATE_PK                    = col_character(),   # Prescription date
    FD_HASH_Rekisterointinumero = col_character(),  # Prescriber hash
    ATC_CODE                   = col_character(),   # ATC drug code
    PRODUCT_CODE               = col_character(),
    .default = col_skip()
  )
)

# Combine chunks and parse prescription date
df_combined <- bind_rows(results)
df2         <- df_combined %>% mutate(DATE_PK = as.Date(DATE_PK, format = "%Y%m%d"))
o17 <- df2
# Rename to o18, o19, ... o22 when repeating for subsequent years

# Combine all prescription years
res <- bind_rows(o17, o18, o19, o20, o21, o22)
nrow(res)

# Save combined prescription data
res %>% write_parquet(paste0("/media/volume/JaninaH/", "fidien_kaikki_reseptit.parquet"))
res <- read_parquet(paste0("/media/volume/JaninaH/", "fidien_kaikki_reseptit.parquet"))


# --- 7.3 Link prescriptions to visits using temporal windows -----------------

# Window 0: Same-day prescriptions (sensitivity check)
same_day <- cdf1 %>%
  left_join(res, by = c("FID", "PVM" = "DATE_PK"))  # n = 1,169,854
same_day %>% write_parquet(paste0("/media/volume/JaninaH/", "reseptien_yhdistys_sama_pv.parquet"))

# Window 7 days: Prescriptions issued from visit date up to 7 days after
candidates <- res %>%
  inner_join(cdf1, by = "FID") %>%
  filter(DATE_PK >= PVM & DATE_PK <= PVM + days(7)) %>%
  mutate(pvm_diff = as.numeric(DATE_PK - PVM))
candidates <- subset(candidates, select = c(1:6, 9, 18))

# Associate each prescription with only one visit (the closest in time)
# but retain all prescriptions per visit
best_matches <- candidates %>%
  arrange(FID, DATE_PK, pvm_diff) %>%
  group_by(FID, DATE_PK, row_id = row_number()) %>%
  slice(1) %>%
  ungroup()

one_week <- cdf1 %>%
  left_join(best_matches, by = c("FID", "PVM"))  # n = 1,295,402
one_week %>% write_parquet(paste0("/media/volume/JaninaH/", "reseptien_yhdistys_viikko.parquet"))


# Window 2 days (primary analysis window): Prescriptions issued on the
# visit date or within 2 days after — chosen to balance capturing
# same-encounter prescriptions while minimising misattribution
candidates <- res %>%
  inner_join(cdf1, by = "FID") %>%
  filter(DATE_PK >= PVM & DATE_PK <= PVM + days(2)) %>%
  mutate(pvm_diff = as.numeric(DATE_PK - PVM))
candidates <- subset(candidates, select = c(1:6, 9, 18))

best_matches <- candidates %>%
  arrange(FID, DATE_PK, pvm_diff) %>%
  group_by(FID, DATE_PK, row_id = row_number()) %>%
  slice(1) %>%
  ungroup()

final <- cdf1 %>%
  left_join(best_matches, by = c("FID", "PVM"))  # n = 1,193,571
final %>% write_parquet(paste0("/media/volume/JaninaH/", "2pv_yhdistetyt_reseptit.parquet"))
final <- read_parquet(paste0("/media/volume/JaninaH/", "2pv_yhdistetyt_reseptit.parquet"))

# Number of prescriptions issued 1–2 days after the visit
sum(final$DATE_PK != final$PVM, na.rm = TRUE)  # 47,475


# --- 7.4 Harmonise prescriber hash and assign care sector -------------------

# Prioritise non-missing visit-level physician hash over prescription-level hash
final <- final %>%
  mutate(
    FD_HASH = if_else(
      !is.na(FD_HASH_Rekisterointinumero.x) &
        FD_HASH_Rekisterointinumero.x != "PUUTTUVA",
      FD_HASH_Rekisterointinumero.x,
      FD_HASH_Rekisterointinumero
    )
  )

# Assign care sector:
#   - Use prescription SECTOR field if available (most precise)
#   - Infer from service provider code (PALTU): 95xxx or 6xxx → private (2)
#   - Default → public (1)
dt <- final %>%
  mutate(
    Sector = case_when(
      !is.na(SECTOR)          ~ as.numeric(SECTOR),
      grepl("^95|^6", PALTU)  ~ 2,
      TRUE                    ~ 1
    )
  )

dt %>% write_parquet(paste0("/media/volume/JaninaH/", "2pv_yhdistetyt_reseptit.parquet"))
dt <- read_parquet(paste0("/media/volume/JaninaH/", "2pv_yhdistetyt_reseptit.parquet"))


