df1_filtered21 <- dt %>% filter(format(PVM, "%Y") == "2021"); id21 <- unique(df1_filtered21$FID)
df1_filtered22 <- dt %>% filter(format(PVM, "%Y") == "2022"); id22 <- unique(df1_filtered22$FID)


# --- 8.2 Read Kela dispensation data in chunks (repeat for each year) --------

csv_name <- "/media/volume/Data_20260319/Kela/FD_2698_165_522_2023_LAAKEOSTOT_2022.csv"  # Update year

results    <- list()
chunk_size <- 3000000

chunk_handler <- function(df, pos) {
  df_filtered <- df %>% filter(FID %in% id22)  # Update year
  results <<- append(results, list(df_filtered))
}

read_delim_chunked(
  file     = csv_name,
  callback = DataFrameCallback$new(chunk_handler),
  delim    = ";",
  locale   = locale(encoding = "UTF-8"),
  chunk_size = chunk_size,
  col_types = cols(
    FID                          = col_character(),
    LAAKEMAARAYS_KIRJOITUS_PV    = col_character(),  # Prescription write date
    VNR_TOIMITETTU               = col_character(),  # Dispensed product code
    FD_HASH_Rekisterointinumero  = col_character(),  # Prescriber hash
    ATC5_KOODI                   = col_character(),  # ATC code of dispensed drug
    DIAGNOOSI_KOODI              = col_character(),  # Diagnosis code on dispensation
    .default = col_skip()
  )
)

df_combined <- bind_rows(results)
df2 <- df_combined %>%
  mutate(LAAKEMAARAYS_KIRJOITUS_PV = as.Date(LAAKEMAARAYS_KIRJOITUS_PV, format = "%Y-%m-%d"))
o22 <- df2
# Rename to o21, o20, ... o17 when repeating for earlier years

# Combine all dispensation years
df_all <- bind_rows(o17, o18, o19, o20, o21, o22)
df_all %>% write_parquet(paste0("/media/volume/JaninaH/", "fidien_kaikki_toimitukset.parquet"))
df_all <- read_parquet(paste0("/media/volume/JaninaH/", "fidien_kaikki_toimitukset.parquet"))


# --- 8.3 Merge dispensation data with visit/prescription dataset -------------

# Remove redundant physician hash columns before merging
dt <- subset(dt, select = -c(FD_HASH_Rekisterointinumero,
                              FD_HASH_Rekisterointinumero.x,
                              FD_HASH_Rekisterointinumero.y))

# Flag dispensed antibiotics: ATC J01 = systemic antibacterials
df_all$ab <- ifelse(grepl("^J01", df_all$ATC5_KOODI, ignore.case = TRUE), 1, 0)

# Link dispensations to visits by patient ID, prescription date, and ATC code
ct <- dt %>%
  left_join(df_all, by = c("FID",
                            "DATE_PK"   = "LAAKEMAARAYS_KIRJOITUS_PV",
                            "ATC_CODE"  = "ATC5_KOODI"))

# Verify physician hash integrity
toim <- ct %>% filter(ab == 1)
sum(is.na(toim$FD_HASH))                   # 85
sum(is.na(df_all$FD_HASH_Rekisterointinumero))  # 99
sum(is.na(res$FD_HASH_Rekisterointinumero))     # 1,463

# Harmonise prescriber hash: prefer non-missing visit-level hash
ct <- ct %>%
  mutate(
    FD_HASH_Rekisterointinro = if_else(
      !is.na(FD_HASH) & FD_HASH != "PUUTTUVA",
      FD_HASH,
      FD_HASH_Rekisterointinumero
    )
  )

# Remove exact duplicate rows
ct <- unique(ct)  # n = 1,182,978

# Antibiotic prescription indicator (from prescription file)
ct$abp <- ifelse(grepl("^J01", ct$ATC_CODE), 1, 0)

# Ensure dispensation antibiotic flag defaults to 0 where no dispensation linked
ct <- ct %>%
  mutate(ab = if_else(is.na(ab), 0, ab))

# Remove duplicates by patient, visit date, sector, ATC code, and prescriber hash
data_clean <- ct %>%
  distinct(FID, PVM, ATC_CODE, Sector, FD_HASH_Rekisterointinro, .keep_all = TRUE)
# n = 1,150,181

table(data_clean$abp)
table(data_clean$ab)
table(data_clean$ab, data_clean$Sector)

data_clean %>% write_parquet(paste0("/media/volume/JaninaH/", "toimitukset_datassa.parquet"))
df <- read_parquet(paste0("/media/volume/JaninaH/", "toimitukset_datassa.parquet"))


