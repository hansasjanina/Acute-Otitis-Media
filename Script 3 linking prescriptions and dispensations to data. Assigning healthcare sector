# --- 8.1 Prepare year-specific patient ID sets (same approach as Section 7) --

list.files("/media/volume/Data_THL_2698_14.02.00_2023_pk1_uudelleen/Kela/")

df1_filtered17 <- dt %>% filter(format(PVM, "%Y") == "2017"); id17 <- unique(df1_filtered17$FID)
df1_filtered18 <- dt %>% filter(format(PVM, "%Y") == "2018"); id18 <- unique(df1_filtered18$FID)
df1_filtered19 <- dt %>% filter(format(PVM, "%Y") == "2019"); id19 <- unique(df1_filtered19$FID)
